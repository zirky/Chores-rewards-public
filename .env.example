# ── chores-rewards – vzor konfiguračního souboru ─────────────────────────────
# Zkopíruj tento soubor jako .env a vyplň své hodnoty.
# Soubor .env NIKDY necommituj do gitu (je v .gitignore).

# ── LNbits ───────────────────────────────────────────────────────────────────

# URL tvé LNbits instance (bez lomítka na konci)
# Příklad: http://192.168.1.10:5000  nebo  https://legend.lnbits.com
LNBITS_URL=http://localhost:5000

# Admin API klíč (Settings → Users → Admin key)
# Potřebný pro: vytváření LNURL-withdraw voucherů, odesílání plateb
LNBITS_ADMIN_KEY=your_lnbits_admin_key_here

# Invoice/Read API klíč (Settings → Users → Invoice key)
# Potřebný pro: ověřování stavu plateb (payment_hash check)
LNBITS_INVOICE_KEY=your_lnbits_invoice_key_here

# ── Databáze ─────────────────────────────────────────────────────────────────

# Cesta k SQLite souboru uvnitř kontejneru (výchozí hodnota stačí)
DB_PATH=/app/data/chores.db

# ── Bezpečnost ───────────────────────────────────────────────────────────────

# JWT secret pro session tokeny (libovolný dlouhý náhodný řetězec)
# Vygeneruj např.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# Počet minut platnosti session tokenu po přihlášení PINem (výchozí: 60)
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── PIN lockout ───────────────────────────────────────────────────────────────
# Po kolika špatných pokusech se uzamkne přihlášení (výchozí: 5)
# PIN_MAX_ATTEMPTS=5

# Na jak dlouho v minutách (výchozí: 15)
# PIN_LOCKOUT_MINUTES=15
